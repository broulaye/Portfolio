# Vite requires env vars to be prefixed with VITE_ to be exposed to the client bundle.

# Sanity CMS — get these from sanity.io/manage
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# EmailJS — get these from emailjs.com (public key is safe to ship)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
